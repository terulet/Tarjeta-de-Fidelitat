# ==========================================================================
# Google Wallet · Tarjeta de Fidelidad · La Gelateria de Roses
# --------------------------------------------------------------------------
# Copia este archivo como `.env` (en local) o configúralo en tu proveedor
# (Vercel → Settings → Environment Variables). NUNCA subas el `.env` real.
# Guía completa paso a paso en: GOOGLE_WALLET_SETUP.md
# ==========================================================================

# ID de emisor (Issuer ID) de tu cuenta de Google Pay & Wallet Console.
# Es un número largo. Ej: 3388000000022345678
GOOGLE_WALLET_ISSUER_ID=PEGAR_ISSUER_ID

# Email de la service account (Google Cloud → IAM → Cuentas de servicio).
# Ej: wallet@gelateria-fidelizacion.iam.gserviceaccount.com
GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=PEGAR_SERVICE_ACCOUNT_EMAIL

# Clave privada de la service account (campo "private_key" del JSON descargado).
# Pega TODO el bloque en UNA sola línea, con los saltos de línea como \n literales.
# Ej: "-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
GOOGLE_WALLET_PRIVATE_KEY="PEGAR_PRIVATE_KEY_CON_\n"

# Sufijo de la clase Loyalty (se concatena al Issuer ID). Deja este valor salvo
# que quieras varias campañas. La clase se crea una vez (ver setup).
GOOGLE_WALLET_CLASS_SUFFIX=gelateria_loyalty_v1

# Orígenes web autorizados a usar el botón "Save to Google Wallet",
# separados por comas. Debe incluir el dominio donde vive la tarjeta cliente.
GOOGLE_WALLET_ORIGINS=https://terulet.github.io
