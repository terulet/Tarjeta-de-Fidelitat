rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function esStaff() {
      return request.auth != null
        && request.auth.token.email == 'staff@lagelateria.app';
    }

    match /clientes/{cardId} {
      allow get: if true;
      allow list: if esStaff();

      // Cliente puede crear su tarjeta pública.
      // Validamos mínimo necesario para que no se quede bloqueado.
      allow create: if request.resource.data.telefono is string
        && request.resource.data.token is string
        && request.resource.data.sellos == 0
        && request.resource.data.monedero == 0
        && request.resource.data.consentimiento == true;

      // Only the authenticated shop account may modify cards.
      allow update: if esStaff();
      allow delete: if false;
    }

    match /telefonos/{telefono} {
      allow get: if true;
      allow list: if esStaff();

      allow create: if request.resource.data.cardId is string
        && request.resource.data.telefono == telefono;
      allow update: if esStaff();
      allow delete: if false;
    }

    match /eventos/{eventoId} {
      allow read, create: if esStaff();
      allow update, delete: if false;
    }

    match /config/publico {
      allow read: if true;
      allow write: if esStaff();
    }

    match /config/staff {
      allow read, write: if esStaff();
    }
  }
}
